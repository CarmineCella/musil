# variables, arithmetic, comparisons

var x = 42
var y = 3.14
var z = x + y
print "x = " x
print "y = " y
print "x + y = " z
print "x * y = " x * y
print "x / 3 = " x / 3
print "(x + 6) * 2 = " (x + 6) * 2

# comparisons return 1.0 (true) or 0.0 (false)
print "x > 10 -> " (x > 10)
print "x < 10 -> " (x < 10)
print "x == 42 -> " (x == 42)
print "x != 42 -> " (x != 42)

# variable reassignment
x = x + 1
print "x after increment = " x
